# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# local agent / editor workspaces
.claude/
.codex/

# local test and browser artifacts
/playwright-report/
/test-results/
/screenshots/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# Google service-account keys — NEVER commit. Used by scripts/hotel-funnel-report.mjs.
*service-account*.json
*gcp*key*.json
secrets/

# Raw GA4 / GSC exports (private analytics dumps). The generated markdown
# reports under 分析/ are kept; the raw drop folder is not committed.
分析/raw/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# station-practice raw image sources (428MB) — only the optimized webp subset
# under public/images/station-practice/sakura/ is committed.
/station_practice
